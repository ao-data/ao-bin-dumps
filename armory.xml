            <tag id="army" name="@ARMORY_TAG_GROUP_SIZE_ARMY" shortname="@ARMORY_TAG_GROUP_SIZE_ARMY_SHORT"/>
        </taggroup>
        <taggroup id="activitytype" name="@ARMORY_TAG_GROUP_ACTIVITY_TYPE">
            <tag id="pve" name="@ARMORY_TAG_ACTIVITY_TYPE_PVE" shortname="@ARMORY_TAG_ACTIVITY_TYPE_PVE_SHORT"/>
