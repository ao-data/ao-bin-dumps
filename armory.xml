            <tag id="dungeons" name="@ARMORY_TAG_ACTIVITY_TYPE_DUNGEONS" shortname="@ARMORY_TAG_ACTIVITY_TYPE_DUNGEONS_SHORT"/>
            <tag id="competitive" name="@ARMORY_TAG_ACTIVITY_TYPE_COMPETITIVE" shortname="@ARMORY_TAG_ACTIVITY_TYPE_COMPETITIVE_SHORT"/>
            <tag id="conquering" name="@ARMORY_TAG_ACTIVITY_TYPE_CONQUERING" shortname="@ARMORY_TAG_ACTIVITY_TYPE_CONQUERING_SHORT"/>
        </taggroup>
    </tagdefinitions>

