    <activities>
        <activity uniquename="openworldsolo" image="Gui/Armory/ARMORY_OPEN_WORLD_SOLO">
            <tags>
                <tag ref="solo"/>
                <tag ref="small_group"/>
                <tag ref="openworld"/>
                <tag ref="pve"/>
                <tag ref="pvp"/>
            </tags>
            <datasetrequirements>
                <or>
                    <and>
                        <duration mindurationminutes="5"/>
                        <metric name="pvpfamegained" minvalue="25000"/>
                    </and>
                    <and>
                        <duration mindurationminutes="5"/>
                        <metric name="pvefamegained" minvalue="100000"/>
                    </and>
                </or>
            </datasetrequirements>
            <scoreweights minuses="3" minusesbaseline="5">
                <weight metric="kills" value="0.2"/>
                <weight metric="deaths" value="-0.2"/>
                <weight metrics="damagedealt,healingdone" value="0.2"/>
                <weight metric="pvpfamegained" value="0.2"/>
                <weight metric="pvefamegained" value="0.3"/>
            </scoreweights>
